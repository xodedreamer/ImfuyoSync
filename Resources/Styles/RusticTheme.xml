<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

  <!-- COLORS -->
  <Color x:Key="EarthBrown">#5A3E2B</Color>
  <Color x:Key="ClayOrange">#C96F32</Color>
  <Color x:Key="SavannaGold">#D9A441</Color>
  <Color x:Key="DeepForestGreen">#2F4F2F</Color>
  <Color x:Key="BoneWhite">#F5F2E9</Color>
  <Color x:Key="CharcoalBlack">#1A1A1A</Color>

  <!-- FONTS -->
  <Style TargetType="Label">
    <Setter Property="TextColor" Value="{StaticResource CharcoalBlack}" />
    <Setter Property="FontFamily" Value="Montserrat" />
  </Style>

  <Style TargetType="Entry">
    <Setter Property="BackgroundColor" Value="{StaticResource BoneWhite}" />
    <Setter Property="TextColor" Value="{StaticResource CharcoalBlack}" />
    <Setter Property="FontFamily" Value="Inter" />
    <Setter Property="HeightRequest" Value="48" />
    <Setter Property="Margin" Value="0,5" />
  </Style>

  <Style TargetType="Button">
    <Setter Property="BackgroundColor" Value="{StaticResource ClayOrange}" />
    <Setter Property="TextColor" Value="White" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="HeightRequest" Value="48" />
    <Setter Property="FontFamily" Value="Montserrat" />
  </Style>

  <!-- CARD STYLE -->
  <Style x:Key="CardStyle" TargetType="Frame">
    <Setter Property="BackgroundColor" Value="White" />
    <Setter Property="BorderColor" Value="{StaticResource EarthBrown}" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="12" />
    <Setter Property="Margin" Value="10,5" />
    <Setter Property="HasShadow" Value="True" />
  </Style>

</ResourceDictionary>

