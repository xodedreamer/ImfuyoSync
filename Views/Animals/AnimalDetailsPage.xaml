<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ImfuyoSync.Views.Animals.AnimalDetailsPage"
             BackgroundColor="{StaticResource BoneWhite}"
             Title="Animal Details">

    <ScrollView>
        <VerticalStackLayout Padding="15">

            <!-- IMAGE CARD -->
            <Border Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,0,20">
                <Image Source="{Binding ImagePath}"
                       Aspect="AspectFill"
                       HeightRequest="220" />
            </Border>

            <!-- SECTION HEADER -->
            <Label Text="Basic Information"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{StaticResource ClayOrange}" />

            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnDefinitions="120,*"
                  Margin="0,10">

                <Label Text="Tag Number:" Grid.Row="0" Grid.Column="0" />
                <Label Text="{Binding TagNumber}" Grid.Row="0" Grid.Column="1" />

                <Label Text="Species:" Grid.Row="1" Grid.Column="0" />
                <Label Text="{Binding Species}" Grid.Row="1" Grid.Column="1" />

                <Label Text="Breed:" Grid.Row="2" Grid.Column="0" />
                <Label Text="{Binding Breed}" Grid.Row="2" Grid.Column="1" />

                <Label Text="Color:" Grid.Row="3" Grid.Column="0" />
                <Label Text="{Binding Color}" Grid.Row="3" Grid.Column="1" />

            </Grid>

            <!-- ACTION BUTTONS -->
            <Button Text="Edit Animal"
                    BackgroundColor="{StaticResource DeepForestGreen}"
                    Margin="0,20,0,0" />

            <Button Text="Delete Animal"
                    BackgroundColor="{StaticResource ClayOrange}"
                    Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>