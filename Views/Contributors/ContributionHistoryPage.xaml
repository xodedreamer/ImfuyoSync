<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ImfuyoSync.Views.Contributors.ContributionHistoryPage"
           BackgroundColor="{StaticResource BoneWhite}"
             Title="Contribution History">

    <CollectionView ItemsSource="{Binding Records}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnDefinitions="*,Auto">

                        <VerticalStackLayout>
                            <Label Text="{Binding Date, StringFormat='{0:dd MMM yyyy}'}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource EarthBrown}" />

                            <Label Text="{Binding Amount, StringFormat='R{0:F2}'}"
                                   FontSize="14"
                                   TextColor="{StaticResource DeepForestGreen}" />
                        </VerticalStackLayout>

                        <Label Grid.Column="1"
                               Text="{Binding IsReimbursement, Converter={StaticResource BoolToTypeConverter}}"
                               FontSize="16"
                               TextColor="{StaticResource ClayOrange}"
                               VerticalOptions="Center" />

                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>